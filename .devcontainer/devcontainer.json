{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:898e5a03283267a0c5d470c599bd01676ef19d9c4b418146d26a517b84438d33",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}