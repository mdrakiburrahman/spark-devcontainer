{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:c215302f66dd429d9beac95c617232501f019835328f568f03e4445d049b0d6f",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse",
        "type=bind,source=${localEnv:HOME}/.azure,target=/home/vscode/.azure"
    ]
}