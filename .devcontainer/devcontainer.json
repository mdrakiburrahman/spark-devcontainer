{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:b06692653365505df19a8810ebeaf9466e47581bf5364fcdac6d57be80772fbc",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}