{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:9be7cd53248b3f46ee25c3b15bbf149568880013af2b3ec70050d458da4d51f5",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}