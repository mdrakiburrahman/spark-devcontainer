{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:a1da457358147e61d7d2da69ffa235ece3d32ebdb18d0ab4e64ea9c6a68f6f7b",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}