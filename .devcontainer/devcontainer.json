{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:1e9ec902c066b05efdc17907d2788f986a7e5cd9af11e31e6f53b29b45bad6c2",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}