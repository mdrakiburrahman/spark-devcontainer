{
    "name": "devcontainer",
    "image": "rakirahman.azurecr.io/devcontainer/spark:5aa26afba9e780205e03a73f97d4a2a52e9b5afe0bdddda37d69fbf414481cac",
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_ADMIN",
        "--device=/dev/fuse",
        "--security-opt=apparmor:unconfined",
        "--add-host=host.docker.internal:host-gateway"
    ],
    "mounts": [
        "type=bind,source=/dev/fuse,target=/dev/fuse"
    ]
}